# =============================================================================
# SurplusToken — Environment Configuration
# Copy to .env and fill in your values before deploying.
# =============================================================================

# ---- Database (PostgreSQL) ----
POSTGRES_USER=surplustoken
POSTGRES_PASSWORD=change_me_to_strong_password
POSTGRES_DB=surplustoken

# ---- Redis ----
REDIS_PASSWORD=change_me_to_strong_redis_password

# ---- New API ----
# Session secret for New API dashboard
SESSION_SECRET=change_me_to_random_64_chars
# JWT secret for relay token auth
JWT_SECRET=change_me_to_random_32_chars
# Crypto key for encrypting channel keys in DB
CRYPTO_KEY=change_me_to_random_32_chars

# ---- CPA Gateway ----
# Management key for CPA's /v0/management API
# New API uses this to proxy OAuth operations
CPA_MANAGEMENT_KEY=surplustoken-admin-key-change-me
# CPA internal API key (used by New API to forward AI requests)
CPA_INTERNAL_API_KEY=sk-surplustoken-gateway-internal

# ---- Service Ports ----
# New API web UI + API
NEW_API_PORT=3000
# CPA gateway API
CPA_PORT=8317

# ---- Optional: External Access URLs ----
# SITE_URL=https://your-domain.com
# CPA_OAuth_CALLBACK_BASE=https://your-domain.com:8317
